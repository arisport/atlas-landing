---
/* Fallback page for password-reset Universal Links.
   iOS with Atlas installed: link opens the app directly (Universal Link).
   Otherwise (Safari/desktop/Android): this page renders. We forward the
   token through to the backend's web-based reset form so anyone without
   the app can still complete the reset. */

const APP_STORE_URL = "https://apps.apple.com/us/app/atlas-fit/id6764618687";
const WEB_RESET_URL = "https://api.myatlas.fit/reset-password/";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password — Atlas Fit</title>
    <meta name="description" content="Reset your Atlas Fit password. Open the link on your iPhone with Atlas installed, or use the web form." />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;800&display=swap"
      rel="stylesheet"
    />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 24px;
        background: #F8F9FB;
        color: #141820;
        text-align: center;
      }
      .wordmark {
        font-size: 20px;
        font-weight: 800;
        color: #1B2A4A;
        margin-bottom: 32px;
        text-decoration: none;
      }
      .wordmark .dot { color: #E2735C; }
      h1 {
        font-size: clamp(24px, 4vw, 32px);
        font-weight: 800;
        margin-bottom: 12px;
        color: #1B2A4A;
        letter-spacing: -0.3px;
      }
      p {
        font-size: 15px;
        line-height: 1.6;
        color: #4A5268;
        max-width: 440px;
        margin-bottom: 24px;
      }
      .web-form-button {
        display: inline-block;
        padding: 14px 28px;
        background: #1B2A4A;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: background 0.15s, transform 0.15s;
        margin-bottom: 24px;
      }
      .web-form-button:hover { background: #233459; transform: translateY(-1px); }
      .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        max-width: 440px;
        width: 100%;
        margin: 8px 0 24px;
        color: #9AA1AD;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #E1E4EA;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #1B2A4A;
        color: #fff;
        padding: 12px 20px;
        border-radius: 8px;
        text-decoration: none;
        transition: transform 120ms ease, background 120ms ease;
        margin-bottom: 32px;
      }
      a.badge:hover { background: #233459; transform: translateY(-1px); }
      .badge svg { flex-shrink: 0; }
      .badge-text { text-align: left; }
      .badge-label { display: block; font-size: 10px; opacity: 0.8; line-height: 1; }
      .badge-store { display: block; font-size: 15px; font-weight: 600; line-height: 1.2; margin-top: 2px; }
      .back-link {
        display: inline-block;
        padding: 10px 20px;
        background: transparent;
        color: #1B2A4A;
        border: 1.5px solid #1B2A4A;
        border-radius: 999px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: background 0.15s, color 0.15s;
      }
      .back-link:hover { background: #1B2A4A; color: #fff; }
    </style>
  </head>
  <body>
    <a href="/" class="wordmark">Atlas<span class="dot">.</span></a>
    <h1>Reset your password</h1>
    <p>
      If you have Atlas Fit installed on your iPhone, open this link on your phone
      and it will jump straight into the app.
    </p>
    <a id="web-reset" href={WEB_RESET_URL} class="web-form-button">Continue in browser</a>
    <div class="divider">or</div>
    <a href={APP_STORE_URL} class="badge" target="_blank" rel="noopener" aria-label="Download Atlas Fit on the App Store">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      <div class="badge-text">
        <span class="badge-label">Download on the</span>
        <span class="badge-store">App Store</span>
      </div>
    </a>
    <a href="/" class="back-link">Back to home</a>
    <script is:inline>
      // Forward the ?token=... query string to the backend's web reset form so
      // the "Continue in browser" button preserves the user's token.
      (function () {
        const params = window.location.search;
        if (!params) return;
        const btn = document.getElementById('web-reset');
        if (btn) btn.href = btn.getAttribute('href') + params;
      })();
    </script>
  </body>
</html>
