---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms & Conditions — Atlas">
  <main class="legal">
    <div class="container">
      <h1>Terms & Conditions</h1>
      <p class="updated">Last updated: April 2026</p>
      <p>Terms and conditions for Atlas are being finalised. By using Atlas during the early-access programme, you agree to use the platform in good faith for its intended purpose — managing fitness programming for your gym, studio, or practice.</p>
      <p>Full terms will be published before the public launch. If you have questions, contact us at <a href="mailto:aris@myatlas.fit">aris@myatlas.fit</a>.</p>
      <a href="/" class="back-link">Back to home</a>
    </div>
  </main>
</Layout>

<style>
  .legal {
    padding: 80px 0;
    min-height: 60vh;
  }
  h1 {
    font-size: 28px;
    font-weight: 800;
    color: var(--navy-700);
    margin-bottom: 8px;
  }
  .updated {
    font-size: 13px;
    color: var(--light-text-tertiary);
    margin-bottom: 32px;
  }
  p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--light-text-secondary);
    max-width: 640px;
    margin-bottom: 16px;
  }
  a { color: var(--coral-600); }
  .back-link {
    display: inline-block;
    margin-top: 24px;
    font-size: 14px;
    font-weight: 600;
  }
</style>
