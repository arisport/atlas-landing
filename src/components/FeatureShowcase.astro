---
const features = [
  {
    id: "assigned-programs",
    title: "Assigned Programs",
    headline: "Build a program. Assign it to a client. They see it instantly.",
    description:
      "Create structured programs from 800+ exercises. Assign to individual clients or groups. Members open the app and their program is waiting — your name on every template.",
    video: "/images/videos/assigned_programs.mp4",
    poster: "/images/videos/assigned_programs_poster.jpg",
  },
  {
    id: "onboarding",
    title: "Effortless Onboarding",
    headline: "Invite one member or a hundred. Your brand from the first tap.",
    description:
      "Send a link, share a gym code, or upload a CSV. Members join in seconds and immediately see your logo, your name, and a verified badge. No manual setup on their end.",
    video: "/images/videos/verify_gym_code.mp4",
    poster: "/images/videos/verify_gym_code_poster.jpg",
  },
  {
    id: "workout-logging",
    title: "Smart Workout Logging",
    headline: "Your last session, pre-filled. PRs, detected automatically.",
    description:
      "Members log sets and the app remembers their last weight. Hit a personal record and it tells them. Pause mid-workout and pick up where they left off.",
    video: "/images/videos/workout_screen.mp4",
    poster: "/images/videos/workout_screen_poster.jpg",
  },
  {
    id: "challenges",
    title: "Challenges & Leaderboards",
    headline: "Set a target. Watch your members chase it.",
    description:
      "Monthly challenges — total sessions, volume, or cardio minutes. Members opt in, progress updates automatically, and the leaderboard keeps them coming back.",
    video: "/images/videos/challenges_screen.mp4",
    poster: "/images/videos/challenges_screen_poster.jpg",
  },
];
---

<section class="showcase section" id="showcase">
  <div class="container">
    <h2 class="showcase-heading">See it in action</h2>

    <div class="showcase-features">
      {features.map((f, i) => (
        <div class:list={["showcase-row", { reverse: i % 2 !== 0 }]}>
          <div class="showcase-text">
            <h3 class="showcase-title">{f.title}</h3>
            <p class="showcase-headline">{f.headline}</p>
            <p class="showcase-desc">{f.description}</p>
          </div>
          <div class="showcase-visual">
            <div class="phone-frame">
              <div class="phone-screen">
                <video
                  data-src={f.video}
                  poster={f.poster}
                  muted
                  loop
                  playsinline
                  class="showcase-video"
                />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase {
    padding-top: calc(var(--section-gap) - 50px);
  }

  .showcase-heading {
    text-align: center;
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 800;
    color: var(--navy-700);
    margin-bottom: var(--space-9);
  }

  .showcase-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  .showcase-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 768px) {
    .showcase-row {
      flex-direction: row;
      align-items: center;
      gap: var(--space-10);
    }

    .showcase-row.reverse {
      flex-direction: row-reverse;
    }
  }

  .showcase-text {
    flex: 1;
  }

  .showcase-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--coral-600);
    margin-bottom: var(--space-2);
  }

  .showcase-headline {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--navy-700);
    margin-bottom: var(--space-3);
  }

  .showcase-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--light-text-secondary);
    max-width: 440px;
  }

  .showcase-visual {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
  }

  .phone-frame {
    width: 220px;
    height: 440px;
    background: var(--navy-800);
    border-radius: var(--radius-2xl);
    padding: var(--space-3);
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .phone-frame {
      width: 240px;
      height: 480px;
    }
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--navy-900);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .showcase-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
</style>

<script>
  // Lazy-load videos when they scroll into view
  const videos = document.querySelectorAll<HTMLVideoElement>('.showcase-video');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const video = entry.target as HTMLVideoElement;
        const src = video.dataset.src;
        if (src && !video.src) {
          video.src = src;
          video.autoplay = true;
          video.play().catch(() => {});
        }
        observer.unobserve(video);
      }
    });
  }, { rootMargin: '200px' });

  videos.forEach((video) => observer.observe(video));
</script>
