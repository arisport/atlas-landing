---
---

<section class="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <h1 class="hero-headline">
        Publish today's workout.<br />Every member sees it instantly.
      </h1>
      <p class="hero-sub">
        Atlas is the fitness platform for gyms, coaches, and rehab
        professionals — with a free workout tracker for everyone.
      </p>
      <div class="hero-actions">
        <a href="#apply" class="btn btn-coral">
          Get Free Early Access
        </a>
        <p class="hero-sub-cta">
          <span class="hero-free-badge">Free for 12 months</span>
          No credit card. No commitment.
        </p>
      </div>
      <a href="/download" class="hero-secondary">
        Or track workouts free — no gym needed
      </a>
    </div>

    <div class="hero-visual">
      <div class="phone-frame">
        <div class="phone-screen">
          <picture>
            <source srcset="/images/screenshots/home_screen_gym_member.webp" type="image/webp" />
            <img
              src="/images/screenshots/home_screen_gym_member.png"
              alt="Atlas home screen showing gym branding, daily program, and challenges"
              class="phone-screenshot"
              width="600"
              height="1303"
            />
          </picture>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-8);
    padding-bottom: var(--section-gap);
    overflow: hidden;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  @media (min-width: 768px) {
    .hero-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--space-10);
    }
  }

  .hero-content {
    flex: 1;
  }

  .hero-headline {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.5px;
    color: var(--navy-700);
  }

  .hero-sub {
    margin-top: var(--space-4);
    font-size: 17px;
    line-height: 1.6;
    color: var(--light-text-secondary);
    max-width: 520px;
  }

  .hero-actions {
    margin-top: var(--space-7);
  }

  .hero-sub-cta {
    margin-top: var(--space-3);
    font-size: 14px;
    color: var(--light-text-tertiary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .hero-free-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--teal-800);
    background: var(--teal-100);
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
    letter-spacing: 0.2px;
  }

  .hero-secondary {
    display: inline-block;
    margin-top: var(--space-5);
    font-size: 14px;
    font-weight: 500;
    color: var(--coral-600);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .hero-secondary:hover {
    border-bottom-color: var(--coral-600);
  }

  /* Phone mockup */
  .hero-visual {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
  }

  .phone-frame {
    width: 260px;
    height: 520px;
    background: var(--navy-800);
    border-radius: var(--radius-2xl);
    padding: var(--space-3);
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .phone-frame {
      width: 280px;
      height: 560px;
    }
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--navy-900);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .phone-screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
</style>
