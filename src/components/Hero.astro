---
---

<section class="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <h1 class="hero-headline">
        Publish today's workout.<br />Every member sees it instantly.
      </h1>
      <p class="hero-sub">
        Atlas is the fitness platform for gyms, coaches, and rehab
        professionals — with a free workout tracker for everyone.
      </p>
      <div class="hero-actions">
        <a href="#founding-partner" class="btn btn-coral">
          Become a Founding Partner
        </a>
        <p class="hero-sub-cta">
          Free for 12 months. No credit card. No commitment.
        </p>
      </div>
      <a href="#solo" class="hero-secondary">
        Or track workouts free — no gym needed
      </a>
    </div>

    <div class="hero-visual">
      <div class="phone-frame">
        <div class="phone-screen">
          <div class="phone-placeholder">
            <div class="phone-placeholder-header"></div>
            <div class="phone-placeholder-card"></div>
            <div class="phone-placeholder-card short"></div>
            <div class="phone-placeholder-card"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-8);
    padding-bottom: var(--section-gap);
    overflow: hidden;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  @media (min-width: 768px) {
    .hero-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--space-10);
    }
  }

  .hero-content {
    flex: 1;
  }

  .hero-headline {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.5px;
    color: var(--navy-700);
  }

  .hero-sub {
    margin-top: var(--space-4);
    font-size: 17px;
    line-height: 1.6;
    color: var(--light-text-secondary);
    max-width: 520px;
  }

  .hero-actions {
    margin-top: var(--space-7);
  }

  .hero-sub-cta {
    margin-top: var(--space-3);
    font-size: 13px;
    color: var(--light-text-tertiary);
  }

  .hero-secondary {
    display: inline-block;
    margin-top: var(--space-5);
    font-size: 14px;
    font-weight: 500;
    color: var(--coral-600);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .hero-secondary:hover {
    border-bottom-color: var(--coral-600);
  }

  /* Phone mockup */
  .hero-visual {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
  }

  .phone-frame {
    width: 260px;
    height: 520px;
    background: var(--navy-800);
    border-radius: 36px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .phone-frame {
      width: 280px;
      height: 560px;
    }
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--navy-900);
    border-radius: 24px;
    overflow: hidden;
    padding: var(--space-6) var(--space-4);
  }

  /* Placeholder skeleton for phone content */
  .phone-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .phone-placeholder-header {
    width: 60%;
    height: 20px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
  }

  .phone-placeholder-card {
    width: 100%;
    height: 72px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
  }

  .phone-placeholder-card.short {
    width: 75%;
    height: 56px;
  }
</style>
