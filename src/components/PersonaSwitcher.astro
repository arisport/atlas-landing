---
const personas = [
  {
    id: "gym-owners",
    tab: "Gym Owners & Studios",
    bullets: [
      "Publish daily workouts — every member sees them instantly",
      "Run challenges with leaderboards to keep members engaged",
      "Invite one member or a hundred — by email, text, gym code, or bulk CSV upload",
      "Members enter your gym code and see your logo and brand from the first tap",
      "Publish programs to the Discover feed — your gym name goes with every template",
      "Admin dashboard: members, trainers, programs — all in one place",
    ],
    screenshot: "/images/screenshots/home_screen_gym_member.png",
    screenshotAlt: "Atlas gym owner view — daily programs, challenges, member management",
    cta: { text: "Get Free Early Access", href: "#apply" },
  },
  {
    id: "solo-coaches",
    tab: "Solo Coaches",
    bullets: [
      "Build structured programs from 800+ exercises with photo demos",
      "Assign programs to clients and track their completion",
      "Invite clients by link or code — they see your name from the first tap",
      "Publish templates to the Discover feed — your name goes with every program",
      "No studio needed. Manage your practice from anywhere.",
    ],
    screenshot: "/images/screenshots/home_screen_gym_member.png",
    screenshotAlt: "Atlas coach view — program builder and client assignments",
    cta: { text: "Get Free Early Access", href: "#apply" },
  },
  {
    id: "physiotherapists",
    tab: "Physiotherapists",
    bullets: [
      "Create recovery protocols with guided exercises",
      "Assign to patients — see when they complete their exercises",
      "Invite patients by link or code — they see your practice name instantly",
      "800+ exercises with photos — filter by muscle group, equipment, movement pattern",
      "Atlas is a fitness tracker with tools for rehab professionals — not medical software",
    ],
    screenshot: "/images/screenshots/home_screen_gym_member.png",
    screenshotAlt: "Atlas physio view — recovery protocols and exercise library",
    cta: { text: "Get Free Early Access", href: "#apply" },
  },
  {
    id: "solo-athletes",
    tab: "Solo Athletes",
    bullets: [
      "Free workout tracker. No gym required. No subscription.",
      "800+ exercises with photo demos — search, filter, build your own workouts",
      "Browse community templates from real trainers and coaches on Discover",
      "Bookmark programs and start workouts directly from the feed",
      "Join a gym later without losing your workout history",
    ],
    screenshot: "/images/screenshots/home_screen_solo_athletes.png",
    screenshotAlt: "Atlas solo athlete view — personal workout tracking without a gym",
    cta: { text: "Download Free", href: "/download", variant: "outline" },
  },
];
---

<section class="personas section" id="features">
  <div class="container">
    <div class="persona-layout">
      <div class="persona-right">
        <div class="phone-frame">
          <div class="phone-screen">
            <img
              id="persona-screenshot"
              src="/images/screenshots/home_screen_gym_member.webp"
              alt="Atlas app screenshot"
              class="screenshot-img"
              width="600"
              height="1303"
            />
          </div>
        </div>
      </div>

      <div class="persona-left">
        <p class="text-overline personas-label">Built for how you work</p>

        <div class="persona-tabs-wrap">
          <div class="persona-tabs" role="tablist" aria-label="Choose your role">
            {personas.map((p, i) => (
              <button
                role="tab"
                aria-selected={i === 0 ? "true" : "false"}
                aria-controls={`panel-${p.id}`}
                id={`tab-${p.id}`}
                class:list={["persona-tab", { active: i === 0 }]}
                data-index={i}
              >
                {p.tab}
              </button>
            ))}
          </div>
        </div>

        {personas.map((p, i) => (
          <div
            role="tabpanel"
            id={`panel-${p.id}`}
            aria-labelledby={`tab-${p.id}`}
            class:list={["persona-panel", { active: i === 0 }]}
            data-index={i}
          >
            <ul class="panel-bullets">
              {p.bullets.map((b) => (
                <li>
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="var(--teal-100)" />
                    <path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a
              href={p.cta.href}
              class:list={["btn", p.cta.variant === "outline" ? "btn-outline" : "btn-coral"]}
            >
              {p.cta.text}
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".persona-tab");
  const panels = document.querySelectorAll<HTMLDivElement>(".persona-panel");
  const screenshotImg = document.getElementById("persona-screenshot") as HTMLImageElement;

  const screenshots = [
    "/images/screenshots/home_screen_gym_member.webp",
    "/images/screenshots/home_screen_gym_member.webp",
    "/images/screenshots/home_screen_gym_member.webp",
    "/images/screenshots/home_screen_solo_athletes.webp",
  ];

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const index = tab.dataset.index;

      tabs.forEach((t) => {
        t.classList.remove("active");
        t.setAttribute("aria-selected", "false");
      });
      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");

      panels.forEach((p) => {
        p.classList.toggle("active", p.dataset.index === index);
      });

      const newSrc = screenshots[Number(index)];
      if (screenshotImg && screenshotImg.src !== newSrc) {
        screenshotImg.src = newSrc;
      }
    });
  });

  // Keyboard navigation
  const tabList = document.querySelector<HTMLDivElement>(".persona-tabs");
  tabList?.addEventListener("keydown", (e) => {
    const tabsArray = Array.from(tabs);
    const current = tabsArray.findIndex((t) => t.classList.contains("active"));
    let next = current;

    if (e.key === "ArrowRight" || e.key === "ArrowDown") {
      next = (current + 1) % tabsArray.length;
      e.preventDefault();
    } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
      next = (current - 1 + tabsArray.length) % tabsArray.length;
      e.preventDefault();
    }

    if (next !== current) {
      tabsArray[next].click();
      tabsArray[next].focus();
    }
  });
</script>

<style>
  .persona-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .persona-layout {
      flex-direction: row;
      align-items: center;
      gap: var(--space-10);
    }
  }

  .persona-left {
    flex: 1;
    order: 1;
  }

  .persona-right {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    order: 2;
  }

  /* On mobile: text first, phone second */
  @media (max-width: 767px) {
    .persona-left { order: 1; }
    .persona-right { order: 2; }
  }

  /* On desktop: phone left, text right */
  @media (min-width: 768px) {
    .persona-right { order: -1; }
  }

  .personas-label {
    color: var(--coral-600);
    margin-bottom: var(--space-3);
  }

  .persona-tabs-wrap {
    position: relative;
    margin-bottom: var(--space-4);
  }

  .persona-tabs-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to right, transparent, var(--light-bg));
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .persona-tabs-wrap::after {
      display: none;
    }
  }

  .persona-tabs {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-2);
  }

  .persona-tabs::-webkit-scrollbar {
    display: none;
  }

  .persona-tab {
    flex-shrink: 0;
    padding: var(--space-2) var(--space-5);
    font-size: 14px;
    font-weight: 600;
    color: var(--light-text-tertiary);
    background: var(--light-surface-2);
    border-radius: var(--radius-full);
    border: 1.5px solid transparent;
    transition: all var(--duration-normal) var(--ease-default);
    white-space: nowrap;
  }

  .persona-tab:hover {
    color: var(--light-text-primary);
    background: var(--light-surface-3);
  }

  .persona-tab.active {
    color: var(--navy-700);
    background: var(--light-surface-1);
    border-color: var(--navy-200);
    box-shadow: var(--shadow-sm);
  }

  /* Panels */
  .persona-panel {
    display: none;
  }

  .persona-panel.active {
    display: block;
    animation: fadeIn var(--duration-slow) var(--ease-enter);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .panel-bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .panel-bullets li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: 15px;
    line-height: 1.5;
    color: var(--light-text-secondary);
  }

  .panel-bullets li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Phone mockup */
  .phone-frame {
    width: 220px;
    height: 440px;
    background: var(--navy-800);
    border-radius: var(--radius-2xl);
    padding: var(--space-3);
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .phone-frame {
      width: 240px;
      height: 480px;
    }
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--navy-900);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
</style>
