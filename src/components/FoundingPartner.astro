---
---

<section class="founding section" id="founding-partner">
  <div class="container">
    <div class="founding-header">
      <h2 class="founding-headline">Become a Founding Partner</h2>
      <p class="founding-sub">
        We're onboarding our first founding partners — limited spots. Free Pro
        access for 12 months. Hands-on onboarding. Direct line to the team.
      </p>
    </div>

    <!-- What you get -->
    <div class="fp-features">
      <ul class="fp-grid">
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Up to 100 members</span>
            <span class="fp-desc">Invite by email, text, or bulk CSV</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Daily programming</span>
            <span class="fp-desc">Publish workouts your members see instantly</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Programs & challenges</span>
            <span class="fp-desc">Structured plans with leaderboards</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Up to 5 trainers</span>
            <span class="fp-desc">Assign roles and manage your team</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Publish to Discover</span>
            <span class="fp-desc">2 community templates per month</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Push notifications</span>
            <span class="fp-desc">New programs and challenges, straight to members</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">Priority support</span>
            <span class="fp-desc">Direct line to the team behind Atlas</span>
          </div>
        </li>
        <li class="fp-item">
          <svg class="fp-check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <div>
            <span class="fp-label">870+ exercises</span>
            <span class="fp-desc">Photo demos, filters, custom exercises</span>
          </div>
        </li>
      </ul>

      <p class="fp-solo-note">
        Your members also get a free workout tracker — history, exercises, and community templates included. No subscription on their end.
      </p>
    </div>

    <p class="founding-credibility">
      "Built by an engineer who listened to gym owners — not a fitness company
      guessing what software should do."
      <span class="credibility-author">— Aris Panayiotou, Founder</span>
    </p>

    <div class="founding-proof">
      <span>870+ exercises</span>
      <span class="proof-dot" aria-hidden="true"></span>
      <span>4 tracking types</span>
      <span class="proof-dot" aria-hidden="true"></span>
      <span>Offline-first sync</span>
      <span class="proof-dot" aria-hidden="true"></span>
      <span>Live admin demo</span>
    </div>

    <!-- Application form -->
    <div class="form-wrap" id="apply">
      <form class="apply-form" id="apply-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="contact_name">Name</label>
            <input type="text" id="contact_name" name="contact_name" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="phone_number">Phone</label>
            <input type="tel" id="phone_number" name="phone_number" required autocomplete="tel" />
          </div>
          <div class="form-group">
            <label for="gym_name">Gym / practice name</label>
            <input type="text" id="gym_name" name="gym_name" required />
          </div>
        </div>

        <div class="form-group">
          <label for="gym_type">Type</label>
          <select id="gym_type" name="gym_type" required>
            <option value="" disabled selected>Select your type</option>
            <option value="gym">Gym / Studio</option>
            <option value="personal_trainer">Solo Coach / Personal Trainer</option>
            <option value="physiotherapist">Physiotherapy Practice</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Tell us about your practice <span class="optional">(optional)</span></label>
          <textarea id="message" name="message" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-coral form-submit" id="form-submit">
          Apply Now
        </button>

        <div class="form-feedback" id="form-feedback" aria-live="polite"></div>
      </form>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById("apply-form") as HTMLFormElement;
  const feedback = document.getElementById("form-feedback")!;
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement;

  const API_URL = "https://api.myatlas.fit/api/v1/onboarding/apply/";

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback.textContent = "";
    feedback.className = "form-feedback";

    // Client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        feedback.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" style="display:inline-block;vertical-align:middle;margin-right:8px"><circle cx="12" cy="12" r="12" fill="var(--teal-100)"/><path d="M7 12l4 4 6-6" stroke="var(--teal-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>Thanks! We\'ll be in touch within 24 hours.<br><span style="opacity:0.7;font-size:13px">We\'ll set up your gym, walk you through the platform, and get your first members invited.</span>';
        feedback.className = "form-feedback success";
        form.reset();

        // Fire conversion events
        if (typeof window.fbq === "function") {
          window.fbq("track", "Lead");
        }
        if (typeof window.ttq !== "undefined") {
          window.ttq.track("SubmitForm");
        }

        // Keep button disabled after success — no re-submit needed
        submitBtn.textContent = "Application Sent";
        return;
      } else {
        const body = await res.json().catch(() => null);
        const code = body?.code;

        if (code === "application_already_pending") {
          feedback.textContent =
            "You already have a pending application. We'll be in touch soon.";
          feedback.className = "form-feedback info";
        } else if (code === "email_already_registered") {
          feedback.textContent =
            "This email is already registered. Check your inbox or contact us.";
          feedback.className = "form-feedback info";
        } else {
          feedback.textContent =
            "Something went wrong. Please try again or email us at aris@myatlas.fit";
          feedback.className = "form-feedback error";
        }
      }
    } catch {
      feedback.textContent =
        "Network error. Please check your connection and try again.";
      feedback.className = "form-feedback error";
    } finally {
      if (submitBtn.textContent !== "Application Sent") {
        submitBtn.disabled = false;
        submitBtn.textContent = "Apply Now";
      }
    }
  });
</script>

<style>
  .founding {
    background-color: var(--navy-900);
    color: #fff;
  }

  .founding-header {
    text-align: center;
    margin-bottom: var(--space-9);
  }

  .founding-headline {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.3px;
  }

  .founding-sub {
    margin-top: var(--space-4);
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-inline: auto;
  }

  /* Feature grid */
  .fp-features {
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-9);
  }

  .fp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-7);
  }

  @media (min-width: 768px) {
    .fp-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6) var(--space-8);
    }
  }

  .fp-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .fp-check {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .fp-label {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  .fp-desc {
    display: block;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
    margin-top: 2px;
  }

  .fp-solo-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.5;
  }

  /* Application form */
  .form-wrap {
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-9);
  }

  .apply-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .form-row {
      flex-direction: row;
      gap: var(--space-5);
    }

    .form-row .form-group {
      flex: 1;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
  }

  .form-group .optional {
    font-weight: 400;
    color: rgba(255, 255, 255, 0.4);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    color: #fff;
    font-size: 15px;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--coral-600);
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='rgba(255,255,255,0.5)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .form-group select option {
    background: var(--navy-800);
    color: #fff;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    align-self: flex-start;
    padding: var(--space-3) var(--space-8);
    font-size: 15px;
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Feedback */
  .form-feedback {
    font-size: 14px;
    min-height: 20px;
  }

  .form-feedback.success {
    color: var(--teal-400);
  }

  .form-feedback.error {
    color: var(--color-error);
  }

  .form-feedback.info {
    color: var(--coral-300);
  }

  /* Credibility */
  .founding-credibility {
    text-align: center;
    font-size: 15px;
    font-style: italic;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: var(--space-6);
  }

  .credibility-author {
    display: block;
    font-style: normal;
    font-weight: 600;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    margin-top: var(--space-2);
  }

  /* Proof strip */
  .founding-proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-9);
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
  }

  .proof-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
  }
</style>
