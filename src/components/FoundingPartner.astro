---
---

<section class="founding section" id="founding-partner">
  <div class="container">
    <div class="founding-header">
      <h2 class="founding-headline">Become a Founding Partner</h2>
      <p class="founding-sub">
        We're onboarding our first founding partners — limited spots. Free Pro
        access for 12 months. Hands-on onboarding. Direct line to the team.
      </p>
    </div>

    <!-- Comparison table -->
    <div class="comparison-wrap">
      <table class="comparison" role="table">
        <thead>
          <tr>
            <th class="comparison-feature-col"></th>
            <th class="comparison-col">Solo<span class="comparison-tag">Free forever</span></th>
            <th class="comparison-col highlight">Founding Partner<span class="comparison-tag">12 months free</span></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Workout tracking</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Exercise library (800+)</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Workout history & offline</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Community templates (browse)</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Member management</td>
            <td class="dash">—</td>
            <td>Up to 100 members</td>
          </tr>
          <tr>
            <td>Daily programming</td>
            <td class="dash">—</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Programs & challenges</td>
            <td class="dash">—</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
          <tr>
            <td>Trainer assignments</td>
            <td class="dash">—</td>
            <td>Up to 5 trainers</td>
          </tr>
          <tr>
            <td>Publish to Discover feed</td>
            <td class="dash">—</td>
            <td>2/month</td>
          </tr>
          <tr>
            <td>Priority support</td>
            <td class="dash">—</td>
            <td class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-label="Yes"><circle cx="10" cy="10" r="10" fill="var(--teal-100)"/><path d="M6 10l3 3 5-5" stroke="var(--teal-700)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Application form -->
    <div class="form-wrap" id="apply">
      <form class="apply-form" id="apply-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="contact_name">Name</label>
            <input type="text" id="contact_name" name="contact_name" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="phone_number">Phone</label>
            <input type="tel" id="phone_number" name="phone_number" required autocomplete="tel" />
          </div>
          <div class="form-group">
            <label for="gym_name">Gym / practice name</label>
            <input type="text" id="gym_name" name="gym_name" required />
          </div>
        </div>

        <div class="form-group">
          <label for="gym_type">Type</label>
          <select id="gym_type" name="gym_type" required>
            <option value="" disabled selected>Select your type</option>
            <option value="gym">Gym / Studio</option>
            <option value="personal_trainer">Solo Coach / Personal Trainer</option>
            <option value="physiotherapist">Physiotherapy Practice</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Tell us about your gym <span class="optional">(optional)</span></label>
          <textarea id="message" name="message" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-coral form-submit" id="form-submit">
          Apply Now
        </button>

        <div class="form-feedback" id="form-feedback" aria-live="polite"></div>
      </form>
    </div>

    <p class="founding-credibility">
      "Built by an engineer who listened to gym owners — not a fitness company
      guessing what software should do."
    </p>
  </div>
</section>

<script>
  const form = document.getElementById("apply-form") as HTMLFormElement;
  const feedback = document.getElementById("form-feedback")!;
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement;

  const API_URL = "https://api.myatlas.fit/api/v1/onboarding/apply/";

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback.textContent = "";
    feedback.className = "form-feedback";

    // Client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        feedback.textContent = "Thanks! We'll be in touch within 24 hours.";
        feedback.className = "form-feedback success";
        form.reset();

        // Fire conversion events
        if (typeof window.fbq === "function") {
          window.fbq("track", "Lead");
        }
        if (typeof window.ttq !== "undefined") {
          window.ttq.track("SubmitForm");
        }
      } else {
        const body = await res.json().catch(() => null);
        const code = body?.code;

        if (code === "application_already_pending") {
          feedback.textContent =
            "You already have a pending application. We'll be in touch soon.";
          feedback.className = "form-feedback info";
        } else if (code === "email_already_registered") {
          feedback.textContent =
            "This email is already registered. Check your inbox or contact us.";
          feedback.className = "form-feedback info";
        } else {
          feedback.textContent =
            "Something went wrong. Please try again or email us directly.";
          feedback.className = "form-feedback error";
        }
      }
    } catch {
      feedback.textContent =
        "Network error. Please check your connection and try again.";
      feedback.className = "form-feedback error";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Apply Now";
    }
  });
</script>

<style>
  .founding {
    background-color: var(--navy-900);
    color: #fff;
  }

  .founding-header {
    text-align: center;
    margin-bottom: var(--space-9);
  }

  .founding-headline {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.3px;
  }

  .founding-sub {
    margin-top: var(--space-4);
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-inline: auto;
  }

  /* Comparison table */
  .comparison-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-10);
  }

  .comparison {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-size: 14px;
  }

  .comparison th,
  .comparison td {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .comparison thead th {
    padding-bottom: var(--space-4);
    font-weight: 700;
    font-size: 15px;
    vertical-align: bottom;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .comparison-feature-col {
    width: 40%;
  }

  .comparison-col {
    width: 30%;
  }

  .comparison-col.highlight {
    color: var(--coral-400);
  }

  .comparison-tag {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    margin-top: var(--space-1);
  }

  .comparison-col.highlight .comparison-tag {
    color: var(--coral-300);
  }

  .comparison td {
    color: rgba(255, 255, 255, 0.8);
  }

  .comparison td.dash {
    color: rgba(255, 255, 255, 0.25);
  }

  .comparison td.check {
    text-align: left;
  }

  .comparison td.check svg {
    display: inline-block;
  }

  /* Application form */
  .form-wrap {
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-9);
  }

  .apply-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .form-row {
      flex-direction: row;
      gap: var(--space-5);
    }

    .form-row .form-group {
      flex: 1;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
  }

  .form-group .optional {
    font-weight: 400;
    color: rgba(255, 255, 255, 0.4);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    color: #fff;
    font-size: 15px;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--coral-600);
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='rgba(255,255,255,0.5)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .form-group select option {
    background: var(--navy-800);
    color: #fff;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    align-self: flex-start;
    padding: var(--space-3) var(--space-8);
    font-size: 15px;
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Feedback */
  .form-feedback {
    font-size: 14px;
    min-height: 20px;
  }

  .form-feedback.success {
    color: var(--teal-400);
  }

  .form-feedback.error {
    color: var(--color-error);
  }

  .form-feedback.info {
    color: var(--coral-300);
  }

  /* Credibility */
  .founding-credibility {
    text-align: center;
    font-size: 15px;
    font-style: italic;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    max-width: 560px;
    margin-inline: auto;
  }
</style>
